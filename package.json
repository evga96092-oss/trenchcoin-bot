{
  "name": "trenchcoin-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:check": "node src/db/check.js",
    "config:check": "node scripts/config-check.js",
    "migrate": "node scripts/migrate.js",
    "migration:status": "node scripts/migration-status.js",
    "backup": "node scripts/backup.js",
    "restore:validate": "node scripts/restore-validate.js",
    "test": "node --test",
    "check": "node --check src/index.js && node --check src/bot.js && node --check src/web/server.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "telegraf": "^4.16.3"
  },
  "engines": {
    "node": "20.x"
  }
}
